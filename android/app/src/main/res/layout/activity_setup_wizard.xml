<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical">

    <!-- 헤더 (그라디언트) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/wizard_title"
            android:textAppearance="@style/TextAppearance.App.Title" />

        <!-- Step Indicator -->
        <com.wearable.monitor.ui.setup.StepIndicatorView
            android:id="@+id/stepIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- 콘텐츠 영역 (Fragment container) -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 하단 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevious"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height_standard"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/btn_previous"
            android:textColor="@color/text_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cornerRadius="@dimen/btn_corner_standard"
            app:strokeColor="@color/border" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height_standard"
            android:layout_weight="2"
            android:text="@string/btn_next"
            android:textColor="@color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/btn_corner_standard" />
    </LinearLayout>

</LinearLayout>
