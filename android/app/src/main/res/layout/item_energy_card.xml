<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <!-- Energy gauge -->
        <com.wearable.monitor.ui.dashboard.EnergyGaugeView
            android:id="@+id/energyGauge"
            android:layout_width="@dimen/energy_circle_size"
            android:layout_height="@dimen/energy_circle_size"
            android:layout_marginEnd="16dp" />

        <!-- Text info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_energy"
                android:textSize="11.5sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvEnergyValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="78 / 100" />

            <TextView
                android:id="@+id/tvEnergyDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="10.5sp"
                android:textColor="@color/text_secondary"
                tools:text="보통 수준 · 충분한 수면 권장" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
