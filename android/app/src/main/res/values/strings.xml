    <!-- Login -->
    <string name="hint_patient_id">환자 ID (예: PT-0001)</string>
    <string name="hint_password">비밀번호</string>
    <string name="btn_login">로그인</string>
    <string name="login_hint">담당 의료진에게 받은 ID와 비밀번호를 입력하세요.</string>

    <!-- Guide -->
    <string name="guide_title">설정 가이드</string>
    <string name="btn_previous">이전</string>
    <string name="btn_next">다음 →</string>
    <string name="btn_start_setup">설정 시작하기 →</string>

    <string name="guide_step1_title">1단계: 워치 페어링</string>
    <string name="guide_step1_desc">Galaxy Watch 7을 스마트폰과 블루투스로 페어링합니다.\nGalaxy Wearable 앱에서 연결 상태를 확인하세요.</string>

    <string name="guide_step2_title">2단계: Samsung Health 설정</string>
    <string name="guide_step2_desc">Samsung Health 앱에서 심박수 연속 측정을 활성화합니다.\n설정 → 심박수 → 지속 측정을 켜주세요.</string>

    <string name="guide_step3_title">3단계: Health Connect 설치</string>
    <string name="guide_step3_desc">Health Connect 앱이 설치되어 있는지 확인합니다.\n설치되어 있지 않다면 Play 스토어에서 다운로드하세요.</string>

    <string name="guide_step4_title">4단계: 데이터 항목 설정</string>
    <string name="guide_step4_desc">Samsung Health에서 수면 중 SpO2 측정을 활성화합니다.\n설정 → 수면 → SpO2 모니터링을 켜주세요.</string>

    <string name="guide_step5_title">5단계: 배터리 최적화 해제</string>
    <string name="guide_step5_desc">백그라운드 수집이 중단되지 않도록 배터리 최적화를 해제합니다.\n다음 설정에서 안내합니다.</string>

