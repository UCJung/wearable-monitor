<?xml version="1.0" encoding="utf-8"?>
<!-- STYLE_GUIDE_ANDROID.md 섹션 3.2 기준 -->
<resources>

    <style name="Theme.WearableMonitor" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:windowBackground">@color/bg_page</item>
    </style>

    <!-- 기본 TextAppearance 부모 (dot-notation 자식 스타일의 암묵적 부모) -->
    <style name="TextAppearance.App" parent="TextAppearance.MaterialComponents.Body1" />

    <!-- 앱 헤더 제목 17sp / 700 / white -->
    <style name="TextAppearance.App.Title">
        <item name="android:textSize">17sp</item>
        <item name="android:fontWeight">700</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- 카드 큰 숫자 값 22sp / 700 / text_primary -->
    <style name="TextAppearance.App.CardValue">
        <item name="android:textSize">22sp</item>
        <item name="android:fontWeight">700</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- 기본 본문 13sp / 400 / text_primary -->
    <style name="TextAppearance.App.Body">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- 보조 설명 / 캡션 11sp / 400 / text_secondary -->
    <style name="TextAppearance.App.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
